{
  "version": 2,
  "builds": [
    {
      "src": "Admin/server.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "Admin/login.html",
          "Admin/dashboard.html",
          "public/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/Admin/server.js"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/Admin/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/Admin/server.js"
    }
  ]
}
